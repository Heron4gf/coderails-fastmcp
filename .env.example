# OpenRouter — powers web_search
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq — powers code_search and code_apply
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

WEB_SEARCH_MODEL=perplexity/sonar-pro-search
CODE_SEARCH_MODEL=qwen/qwen3.6-27b
CODE_APPLY_MODEL=qwen/qwen3.6-27b
CODE_SEARCH_MAX_STEPS=16
